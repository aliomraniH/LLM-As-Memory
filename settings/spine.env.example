# MCP_Assist spine auth. Copy to settings/spine.env (gitignored via *.env) and fill in.
# The harness sends it as: Authorization: Bearer <token>
# Same token goes to the interactive surface:
#   claude mcp add --transport http MCP_Assist https://mcp-assist-memory.replit.app/mcp \
#     --header "Authorization: Bearer <token>"
SPINE_AUTH_TOKEN=
