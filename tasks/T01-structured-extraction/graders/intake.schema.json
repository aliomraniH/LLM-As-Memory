{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntakeRecords",
  "type": "array",
  "minItems": 3,
  "maxItems": 3,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["patient_name", "date_of_birth", "referral_date", "referring_provider",
                 "referring_organization", "referral_reason_code", "referral_reason_text",
                 "urgency", "medications"],
    "properties": {
      "patient_name": { "type": "string" },
      "date_of_birth": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "referral_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "referring_provider": { "type": "string" },
      "referring_organization": { "type": "string" },
      "referral_reason_code": { "enum": ["HTN-UNCTRL", "CP-NEW", "DM2-UNCTRL", "OTHER"] },
      "referral_reason_text": { "type": "string" },
      "urgency": { "enum": ["routine", "semi-urgent", "urgent"] },
      "medications": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "dose_value", "dose_unit", "route", "frequency"],
          "properties": {
            "name": { "type": "string" },
            "dose_value": { "type": "number" },
            "dose_unit": { "enum": ["mg", "mcg", "g", "mL", "units"] },
            "route": { "enum": ["oral", "subcutaneous", "intravenous", "topical", "inhaled"] },
            "frequency": { "type": "string" }
          }
        }
      }
    }
  }
}
